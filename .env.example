GOOGLE_CLIENT_ID=
ANIME_AUTH_ALLOWED_EMAILS=
ANIME_AUTH_ALLOWED_DOMAINS=
ANIME_ADMIN_EMAIL=
# At least 32 bytes; required for restart/replica-stable Google OAuth state.
ANIME_GOOGLE_AUTH_STATE_SECRET=
ANIME_SESSION_SECURE=
ANIME_SYNC_TOKEN=
# Separate high-entropy credential for trusted AnimeGO manifest/push access.
ANIMEGO_PUSH_TOKEN=
ANIME_SYNC_MODE=daily
ANIME_SYNC_TIMEOUT_SECONDS=1800
ANIME_INTERNAL_DAILY_SYNC=
ANIME_DAILY_SYNC_UTC_HOUR=2
ANIME_DAILY_SYNC_UTC_MINUTE=0
# Successful readiness checks are cached longer than failures.
ANIME_READINESS_CACHE_TTL_SECONDS=60
ANIME_READINESS_FAILURE_CACHE_TTL_SECONDS=2
